{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Project: Build (Dev)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "${config:custom.tasksFilePath}",
                "build"
            ],
            "problemMatcher": []
        },
        {
            "label": "Project: Build (Prod)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "${config:custom.tasksFilePath}",
                "build",
                "--is-prod"
            ],
            "problemMatcher": []
        },
        {
            "label": "Project: Start",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "${config:custom.tasksFilePath}",
                "serve"
            ],
            "problemMatcher": []
        },
    ]
}